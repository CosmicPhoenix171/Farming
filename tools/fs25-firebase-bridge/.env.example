# Absolute path to your Firebase service account key JSON file
SERVICE_ACCOUNT_PATH=C:\\path\\to\\serviceAccountKey.json

# Firebase Realtime Database URL
FIREBASE_DATABASE_URL=https://farming-66ed6-default-rtdb.firebaseio.com

# Absolute path to the JSON snapshot exported by your FS25 server/mod
FS25_SNAPSHOT_PATH=C:\\path\\to\\fs25-prices.json

# Realtime DB path where live prices are written
FIREBASE_PRICES_PATH=fs25/livePrices

# Optional: if true, print full payload summary on each upload
VERBOSE=false
